@model IEnumerable<TextAnalyzer.Models.IdeaPair>
@{
    ViewData["Title"] = "Similitudes entre Ideas";
    double currentThreshold = (double)(ViewBag.Threshold ?? 0.20);
}

<div class="container">
    <div class="flex justify-between items-center mb-4">
        <h2>Análisis de Similitud de Ideas</h2>
        <a asp-action="Dashboard" class="btn-primary" style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary); text-decoration: none;">
            ← Volver al Panel
        </a>
    </div>

    <!-- Threshold Filter Control -->
    <div class="glass-panel mb-4" style="padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem;">
        <div>
            <h4 style="margin: 0; color: var(--accent);">Nivel de Exigencia</h4>
            <p style="margin: 0; font-size: 0.9rem; color: var(--text-secondary);">Muestra ideas con este porcentaje de similitud o más.</p>
        </div>
        <form method="get" asp-action="CompareIdeas" style="display: flex; gap: 1rem; align-items: center; margin: 0;">
            <input type="range" name="threshold" min="0.05" max="1.0" step="0.05" value="@currentThreshold" 
                   oninput="document.getElementById('thresholdValue').innerText = Math.round(this.value * 100) + '%';"
                   style="cursor: pointer;" />
            <span id="thresholdValue" style="font-weight: bold; width: 40px;">@(Math.Round(currentThreshold * 100))%</span>
            <button type="submit" class="btn-primary" style="padding: 0.5rem 1rem;">Filtrar</button>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-panel text-center" style="padding: 3rem;">
            <h3 style="color: var(--text-secondary);">No se encontraron similitudes por encima del umbral (@(Math.Round(currentThreshold * 100))%).</h3>
            <p style="color: var(--text-secondary);">Esto es una buena señal, ¡las ideas de los equipos son originales!</p>
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            @foreach (var pair in Model)
            {
                int percentage = (int)Math.Round(pair.SimilarityScore * 100);
                
                string borderColor = percentage >= 80 ? "#ef4444" : (percentage >= 50 ? "#f59e0b" : "#3b82f6");
                string badgeBg = percentage >= 80 ? "rgba(239, 68, 68, 0.2)" : (percentage >= 50 ? "rgba(245, 158, 11, 0.2)" : "rgba(59, 130, 246, 0.2)");
                string badgeColor = percentage >= 80 ? "#f87171" : (percentage >= 50 ? "#fbbf24" : "#60a5fa");

                <div class="glass-panel idea-card" style="padding: 1.5rem; border-left: 4px solid @borderColor;">
                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--glass-border); padding-bottom: 1rem; margin-bottom: 1rem;">
                        <h3 style="margin: 0;">Coincidencia Detectada</h3>
                        <div style="background: @badgeBg; color: @badgeColor; font-weight: 600; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 1.1rem;">
                            @percentage% de similitud
                        </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                        <!-- Idea 1 -->
                        <div style="background: rgba(0,0,0,0.1); padding: 1rem; border-radius: 8px;">
                            <strong style="display: block; color: var(--accent); margin-bottom: 0.5rem; font-size: 1.1rem;">
                                Equipo: @pair.Team1Name
                            </strong>
                            <p style="white-space: pre-wrap; font-size: 0.95rem; line-height: 1.5; margin: 0; color: var(--text-primary);">@pair.Idea1</p>
                        </div>
                        
                        <!-- Idea 2 -->
                        <div style="background: rgba(0,0,0,0.1); padding: 1rem; border-radius: 8px;">
                            <strong style="display: block; color: var(--accent); margin-bottom: 0.5rem; font-size: 1.1rem;">
                                Equipo: @pair.Team2Name
                            </strong>
                            <p style="white-space: pre-wrap; font-size: 0.95rem; line-height: 1.5; margin: 0; color: var(--text-primary);">@pair.Idea2</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
