@{
    ViewData["Title"] = "Login Profesor";
}

<div class="glass-panel mx-auto" style="max-width: 400px; margin-top: 5rem;">
    <h2 class="text-center mb-4">Acceso Profesor</h2>

    <form asp-action="Login" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

        <div class="form-group">
            <label class="form-label">Usuario</label>
            <input name="username" class="form-control" required />
        </div>

        <div class="form-group">
            <label class="form-label">Contraseña</label>
            <input name="password" type="password" class="form-control" required />
        </div>

        <button type="submit" class="btn-primary mt-4" style="background: linear-gradient(135deg, #f43f5e 0%, #be123c 100%);">
            Ingresar
        </button>
    </form>
</div>
